# ─────────────────────────────────────────────────────────────
# EXTINVAL GROUP — Environment Variables
# Copy this file to .env.local for local development.
# In Vercel: Settings → Environment Variables → add all below.
# ─────────────────────────────────────────────────────────────

# Supabase — Server-side ONLY (never exposed to browser)
# Get from: supabase.com → project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...YOUR_SERVICE_ROLE_KEY

# CMS Authentication — Server-side ONLY
# The password your marketing team uses to activate the inline editor
CMS_PASSWORD=extinval2026

# JWT Secret — Server-side ONLY
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-very-long-random-secret-here-minimum-32-chars

# Contact Form (Formspree) — can be public
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id
